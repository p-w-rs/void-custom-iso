#!/usr/bin/env fish

# setup-config
# Run on the HOST before chrooting.
# Asks the user for all configuration values and saves them to ./chroot/config.

set CONFIG_FILE (dirname (status filename))/chroot/config

echo "=== Void Linux Installation Configuration ==="
echo ""

read -P "Hostname [void]: "             HOSTNAME
read -P "Timezone [America/Boise]: "    TIMEZONE
read -P "Keymap [us]: "                 KEYMAP
read -P "Locale [en_US.UTF-8]: "        LOCALE
read -P "New username [void]: "         NEW_USER

echo ""
echo "Services to enable (space-separated, e.g: acpid chronyd dhcpcd sshd wpa_supplicant)"
read -P "Services: [acpid chronyd dhcpcd sshd wpa_supplicant]" -t SERVICES

# ── Apply defaults for any empty values ───────────────────────────────────────
if test -z "$HOSTNAME";  set HOSTNAME  void;            end
if test -z "$TIMEZONE";  set TIMEZONE  America/Boise; end
if test -z "$KEYMAP";    set KEYMAP    us;               end
if test -z "$LOCALE";    set LOCALE    en_US.UTF-8;      end
if test -z "$NEW_USER";  set NEW_USER  void;             end
if test -z "$SERVICES";  set SERVICES  "acpid chronyd dhcpcd sshd wpa_supplicant"; end

echo ""
echo ">>> Writing config to $CONFIG_FILE..."

echo "# void-config.fish - Generated by setup-config" > $CONFIG_FILE
echo "# Do not edit manually unless you know what you are doing." >> $CONFIG_FILE
echo "" >> $CONFIG_FILE
echo "set HOSTNAME    \"$HOSTNAME\""   >> $CONFIG_FILE
echo "set TIMEZONE    \"$TIMEZONE\""   >> $CONFIG_FILE
echo "set KEYMAP      \"$KEYMAP\""     >> $CONFIG_FILE
echo "set LOCALE      \"$LOCALE\""     >> $CONFIG_FILE
echo "set NEW_USER    \"$NEW_USER\""   >> $CONFIG_FILE
echo "set SERVICES    $SERVICES"       >> $CONFIG_FILE

echo ""
echo ">>> Config saved to $CONFIG_FILE"
echo "    Review it, then run: sudo fish run-chroot"
