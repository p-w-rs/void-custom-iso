#!/usr/bin/env fish

# ── Configuration ─────────────────────────────────────────────────────────────
# Usage: ./mount-disk <device>
# Examples:
#   ./mount-disk /dev/loop0      (disk image)
#   ./mount-disk /dev/sda        (SATA/SCSI drive)
#   ./mount-disk /dev/nvme0n1    (NVMe drive)

set MOUNT_ROOT /mnt

# ── Argument handling ──────────────────────────────────────────────────────────
if test (count $argv) -ne 1
    echo "Usage: "(status filename)" <device>"
    echo "  e.g. "(status filename)" /dev/loop0"
    echo "  e.g. "(status filename)" /dev/sda"
    echo "  e.g. "(status filename)" /dev/nvme0n1"
    exit 1
end

set DEV $argv[1]

# Detect partition suffix:
#   NVMe and loop devices append 'p' before the number (e.g. nvme0n1p1, loop0p1)
#   SATA/SCSI drives do not                            (e.g. sda1)
if string match -qr '(nvme|loop)' $DEV
    set PART_EFI  {$DEV}p1
    set PART_SWAP {$DEV}p2
    set PART_ROOT {$DEV}p3
else
    set PART_EFI  {$DEV}1
    set PART_SWAP {$DEV}2
    set PART_ROOT {$DEV}3
end

echo "Device:     $DEV"
echo "EFI:        $PART_EFI"
echo "Swap:       $PART_SWAP"
echo "Root:       $PART_ROOT"
echo "Mount root: $MOUNT_ROOT"
echo ""

# ── 1. Mount root filesystem ───────────────────────────────────────────────────
echo "Mounting root filesystem..."
sudo mount $PART_ROOT $MOUNT_ROOT || exit 1

# ── 2. Mount EFI System Partition ─────────────────────────────────────────────
echo "Mounting EFI partition..."
sudo mkdir -p $MOUNT_ROOT/boot/efi || exit 1
sudo mount $PART_EFI $MOUNT_ROOT/boot/efi || exit 1

# ── 3. Enable swap ─────────────────────────────────────────────────────────────
# Swap is pre-formatted; we only need swapon here.
echo "Enabling swap..."
sudo swapon $PART_SWAP || exit 1

echo ""
echo "Done! Filesystems mounted under $MOUNT_ROOT"
echo ""
echo "To unmount when finished:"
echo "  sudo swapoff $PART_SWAP"
echo "  sudo umount $MOUNT_ROOT/boot/efi"
echo "  sudo umount $MOUNT_ROOT"
