#!/usr/bin/env fish

# ── Configuration ─────────────────────────────────────────────────────────────
set REPO_MAIN       https://repo-default.voidlinux.org/current
set REPO_NONFREE    https://repo-default.voidlinux.org/current/nonfree
set ARCH            x86_64
set MOUNT_ROOT      /mnt

# Packages to ignore (will not be installed even as dependencies)
set IGNORE_PKGS     linux linux-headers

# Packages to install with base-system
set BASE_PACKAGES   base-system linux-mainline linux-mainline-headers void-repo-nonfree \
                    linux-firmware linux-firmware-dvb linux-firmware-intel linux-firmware-network linux-firmware-nvidia \
                    sudo acpi chrony dhcpcd openssh wpa_supplicant dbus bluez \
                    fish-shell net-tools xtools parted grub-x86_64-efi glibc-locales

# ── 1. Copy XBPS RSA keys ──────────────────────────────────────────────────────
echo "Copying XBPS RSA keys..."
sudo mkdir -p $MOUNT_ROOT/var/db/xbps/keys || exit 1
sudo cp /var/db/xbps/keys/* $MOUNT_ROOT/var/db/xbps/keys/ || exit 1

# ── 2. Write ignorepkg config before installation ─────────────────────────────
echo "Writing ignorepkg config..."
sudo mkdir -p $MOUNT_ROOT/etc/xbps.d || exit 1
for pkg in $IGNORE_PKGS
    echo "ignorepkg=$pkg" | sudo tee -a $MOUNT_ROOT/etc/xbps.d/10-ignore.conf
end

# ── 3. Bootstrap base installation ────────────────────────────────────────────
echo "Installing: $BASE_PACKAGES"
echo "Repos:      $REPO_MAIN $REPO_NONFREE"
echo "Arch:       $ARCH"
echo "Target:     $MOUNT_ROOT"
echo ""

sudo env XBPS_ARCH=$ARCH xbps-install -Su -R $REPO_MAIN -R $REPO_NONFREE -r $MOUNT_ROOT $BASE_PACKAGES || exit 1

echo ""
echo "Done! Base system installed to $MOUNT_ROOT"
echo "Ignored packages: $IGNORE_PKGS"
