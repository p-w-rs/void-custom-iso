#!/usr/bin/env fish

# install-nvidia
# Runs INSIDE the chroot.
# Installs the NVIDIA open kernel module driver (580.x) and CUDA toolkit (13.1.x)
# from official .run installers
#
# Must run AFTER install-pkgs and BEFORE finalize, so that the DKMS module is
# built and present when finalize runs xbps-reconfigure -fa (which rebuilds
# the initramfs and includes the module).
#
# Blackwell (RTX 50xx) cards require --open (open kernel module variant).
#
# Prerequisites installed by install-pkgs (packages/nvidia.fish):
#   dkms linux-mainline-headers gcc make pkg-config libglvnd libglvnd-devel nvtop
#
# ── Download these on the host before running run-chroot ──────────────────────
# Driver (check https://www.nvidia.com/en-us/drivers/unix/ for latest):
#   wget -P /mnt/tmp https://us.download.nvidia.com/XFree86/Linux-x86_64/580.126.18/NVIDIA-Linux-x86_64-580.126.18.run
#
#   NVIDIA-Linux-x86_64-580.126.18.run
#
# CUDA (check https://developer.nvidia.com/cuda-downloads for latest runfile URL):
#   wget -P /mnt/tmp https://developer.download.nvidia.com/compute/cuda/13.1.1/local_installers/cuda_13.1.1_590.48.01_linux.run
#
#   cuda_13.1.1_590.48.01_linux.run
# ─────────────────────────────────────────────────────────────────────────────

set DRIVER_VER   580.126.18
set CUDA_VER     13.1.1
set DRIVER_RUN   NVIDIA-Linux-x86_64-{$DRIVER_VER}.run
set CUDA_RUN     cuda_{$CUDA_VER}_590.48.01_linux.run
set CUDA_PATH    /usr/local/cuda-13.1
set ASSETS       /tmp

echo "=== NVIDIA Driver + CUDA Installation ==="
echo "    Driver : $DRIVER_VER"
echo "    CUDA   : $CUDA_VER"
echo ""

# ── 1. Install NVIDIA driver ───────────────────────────────────────────────────
echo ""
echo ">>> Installing NVIDIA driver $DRIVER_VER..."

if not test -f $ASSETS/$DRIVER_RUN
    echo "ERROR: $ASSETS/$DRIVER_RUN not found."
    echo "       Run the wget command above on the host, then retry."
    exit 1
end

chmod +x $ASSETS/$DRIVER_RUN

# --open              : open kernel module — required for Blackwell (RTX 50xx)
# --dkms              : register with DKMS so the module rebuilds on kernel updates
# --silent            : non-interactive
# --install-libglvnd  : install NVIDIA's libglvnd GL/Vulkan dispatch libraries
# --no-nvidia-modprobe: skip the setuid nvidia-modprobe helper (not needed on runit)
# --no-backup         : skip backing up conflicting files
# --no-questions      : suppress any remaining interactive prompts
$ASSETS/$DRIVER_RUN \
    --open \
    --dkms \
    --silent \
    --install-libglvnd \
    --no-nvidia-modprobe \
    --no-backup \
    --no-questions || exit 1

echo ">>> Driver installed."

# ── 2. Install CUDA toolkit ────────────────────────────────────────────────────
echo ""
echo ">>> Installing CUDA $CUDA_VER..."

if not test -f $ASSETS/$CUDA_RUN
    echo "ERROR: $ASSETS/$CUDA_RUN not found."
    echo "       Run the wget command above on the host, then retry."
    exit 1
end

chmod +x $ASSETS/$CUDA_RUN

# --silent         : non-interactive
# --toolkit        : install the toolkit only
# --toolkitpath    : where to install it
# --no-driver      : skip the bundled driver — we already installed it above
# --no-opengl-libs : skip OpenGL libs — already handled by libglvnd in step 2
# --no-drm         : skip DRM libs for the same reason
# --no-man-page    : skip man pages
# --override       : suppress version mismatch warnings between toolkit and driver
$ASSETS/$CUDA_RUN \
    --silent \
    --toolkit \
    --toolkitpath=$CUDA_PATH \
    --no-driver \
    --no-opengl-libs \
    --no-drm \
    --no-man-page \
    --override || exit 1

# Stable version-independent symlink
ln -sf $CUDA_PATH /usr/local/cuda

echo ""
echo ">>> install-nvidia complete."
echo "    CUDA installed to : $CUDA_PATH  →  /usr/local/cuda"
echo "    Kernel module     : built via DKMS, will be in initramfs after finalize"
