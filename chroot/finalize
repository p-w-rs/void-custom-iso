#!/usr/bin/env fish
# finalize
# Runs INSIDE the chroot.
# Reconfigures all packages so the kernel, initramfs, and
# other post-install hooks are fully applied.

echo "=== Finalizing Installation ==="
echo ""

echo ">>> Reconfiguring all packages (this sets up the kernel/initramfs)..."
xbps-reconfigure -fa || exit 1

echo ""
echo ">>> finalize complete."
