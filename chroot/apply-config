#!/usr/bin/env fish

# apply-config
# Runs INSIDE the chroot.
# Configures hostname, locale, rc.conf, root password, and new user.

set SCRIPT_DIR (dirname (status filename))
source $SCRIPT_DIR/config

echo "=== Void Linux System Configuration ==="
echo ""

# ── Hostname ──────────────────────────────────────────────────────────────────
echo ">>> Setting hostname: $HOSTNAME"
echo $HOSTNAME > /etc/hostname

# ── rc.conf ───────────────────────────────────────────────────────────────────
echo ">>> Writing /etc/rc.conf..."
echo "TIMEZONE=\"$TIMEZONE\""     >  /etc/rc.conf
echo "HARDWARECLOCK=\"UTC\""      >> /etc/rc.conf
echo "KEYMAP=\"$KEYMAP\""         >> /etc/rc.conf
echo "FONT=\"lat9w-16\""          >> /etc/rc.conf
echo "TTYS=2"                     >> /etc/rc.conf

# ── Locale ────────────────────────────────────────────────────────────────────
echo ">>> Enabling locale: $LOCALE"
set LOCALE_ESCAPED (string escape --style=regex $LOCALE)
sed -i -E "s/^#($LOCALE_ESCAPED.*)/\1/" /etc/default/libc-locales

echo ">>> Generating locale files..."
xbps-reconfigure -f glibc-locales || exit 1

# ── sudo ──────────────────────────────────────────────────────────────────────
echo ">>> Granting wheel group sudo access..."
echo "%wheel ALL=(ALL) ALL" > /etc/sudoers.d/wheel
chmod 440 /etc/sudoers.d/wheel

# ── wpa_supplicant stub config ────────────────────────────────────────────────
# Creates a minimal valid config so the service starts cleanly on any hardware.
# Add networks after first boot with: wpa_passphrase SSID PASS >> /etc/wpa_supplicant/wpa_supplicant.conf
echo ">>> Writing wpa_supplicant stub config..."
mkdir -p /etc/wpa_supplicant
if not test -f /etc/wpa_supplicant/wpa_supplicant.conf
    echo "ctrl_interface=/var/run/wpa_supplicant" >  /etc/wpa_supplicant/wpa_supplicant.conf
    echo "update_config=1"                        >> /etc/wpa_supplicant/wpa_supplicant.conf
    echo "eapol_version=1"                        >> /etc/wpa_supplicant/wpa_supplicant.conf
    echo "ap_scan=1"                              >> /etc/wpa_supplicant/wpa_supplicant.conf
    echo "fast_reauth=1"                          >> /etc/wpa_supplicant/wpa_supplicant.conf
end
chmod 600 /etc/wpa_supplicant/wpa_supplicant.conf

# ── Root password ─────────────────────────────────────────────────────────────
echo ""
echo ">>> Set the ROOT password:"
passwd root

# ── New user ──────────────────────────────────────────────────────────────────
echo ""
echo ">>> Creating user: $NEW_USER"
# Groups included: all groups that grant useful hardware/system access
# Groups excluded: root, kmem (raw memory), tape, daemon, utmp, adm, mail,
#                  nogroup, usbmon, tty, bin, sys (historical/security risk)
useradd -m -G wheel,audio,video,cdrom,optical,kvm,xbuilder,bluetooth,network,storage,scanner,plugdev,input,users,dialout,lp,floppy,disk -s /usr/bin/fish $NEW_USER

echo ">>> Set password for $NEW_USER:"
passwd $NEW_USER

# ── Summary ───────────────────────────────────────────────────────────────────
echo ""
echo ">>> apply-config complete."
echo "    Hostname : $HOSTNAME"
echo "    Timezone : $TIMEZONE"
echo "    Locale   : $LOCALE"
echo "    User     : $NEW_USER"
echo "    Groups   : wheel audio video cdrom optical kvm xbuilder bluetooth"
echo "               network storage scanner plugdev input users dialout lp floppy disk"
