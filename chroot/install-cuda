#!/usr/bin/env fish

# install-cuda
# Runs INSIDE the chroot.
# Installs the CUDA toolkit only — skips the bundled driver since
# install-nvdriver already installed the correct open kernel module version.
#
# Run order: install-pkgs → install-nvdriver → install-cuda → finalize

set DRIVER_VER      580.126.18
set CUDA_VER        13.0.0
set CUDA_MAJOR      13.0
set CUDA_BUNDLED    580.65.06
set CUDA_RUN        /tmp/cuda_{$CUDA_VER}_{$CUDA_BUNDLED}_linux.run
set CUDA_PATH       /usr/local/cuda-{$CUDA_MAJOR}

echo "=== CUDA Toolkit Installation ==="
echo ""

chmod +x $CUDA_RUN

# --toolkit / --toolkitpath : install toolkit only to versioned path
# --no-driver               : skip bundled driver (open kernel module already installed)
# --no-opengl-libs          : libglvnd already provides these
# --no-drm                  : same
# --no-man-page             : keep install lean
# --override                : suppress version mismatch warnings (no running driver in chroot)
echo ">>> Installing CUDA $CUDA_VER to $CUDA_PATH..."
$CUDA_RUN \
    --silent \
    --toolkit \
    --toolkitpath=$CUDA_PATH \
    --no-opengl-libs \
    --no-drm \
    --no-man-page \
    --override || exit 1

ln -sf $CUDA_PATH /usr/local/cuda

echo ""
echo ">>> install-cuda complete."
