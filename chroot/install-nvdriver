#!/usr/bin/env fish

# install-nvdriver
# Runs INSIDE the chroot.
# Installs the NVIDIA open kernel module driver from the official .run installer.
# Uses a manual extract-and-build approach to avoid the tegra headers bug in
# the .run installer's built-in build system on x86_64 + CONFIG_COMMON_CLK.
#
# Run order: install-pkgs → install-nvdriver → install-cuda → finalize

set DRIVER_VER  590.48.01
set DRIVER_RUN  /tmp/NVIDIA-Linux-x86_64-{$DRIVER_VER}.run
set EXTRACT_DIR /tmp/nvidia-extract
set KERNEL_VER  (uname -r)
set KERNEL_SRC  /usr/src/kernel-headers-{$KERNEL_VER}

echo "=== NVIDIA Driver Installation ==="
echo ""

# ── Step 1: Extract ───────────────────────────────────────────────────────────
# --extract-only lets us drive the kernel build ourselves with explicit
# TARGET_ARCH=x86_64, bypassing the installer's broken tegra detection.
echo ">>> Extracting..."
rm -rf $EXTRACT_DIR
$DRIVER_RUN --extract-only --target $EXTRACT_DIR || exit 1

# ── Step 2: Userspace components ─────────────────────────────────────────────
echo ">>> Installing userspace components..."
$DRIVER_RUN \
    --silent \
    --no-kernel-module \
    --install-libglvnd \
    --no-nvidia-modprobe \
    --no-nouveau-check \
    --no-backup \
    --no-questions || exit 1

# ── Step 3: Build open kernel modules ────────────────────────────────────────
# TARGET_ARCH=x86_64 prevents the Kbuild system from pulling in arm64/tegra
# code paths even when CONFIG_COMMON_CLK is set.
echo ">>> Building kernel modules..."
cd $EXTRACT_DIR/kernel-open
make modules \
    TARGET_ARCH=x86_64 \
    KERNEL_UNAME=$KERNEL_VER \
    SYSSRC=$KERNEL_SRC \
    SYSOUT=$KERNEL_SRC \
    NV_VERBOSE=1 \
    -j(nproc) || exit 1

# ── Step 4: Install modules ───────────────────────────────────────────────────
echo ">>> Installing kernel modules..."
make modules_install \
    TARGET_ARCH=x86_64 \
    KERNEL_UNAME=$KERNEL_VER || exit 1

# ── Step 5: Register with DKMS ───────────────────────────────────────────────
# Copies source to /usr/src/nvidia-$DRIVER_VER so DKMS rebuilds on kernel updates.
echo ">>> Registering with DKMS..."
mkdir -p /usr/src/nvidia-$DRIVER_VER
cp -r $EXTRACT_DIR/kernel-open/* /usr/src/nvidia-$DRIVER_VER/

dkms add     -m nvidia -v $DRIVER_VER --force          || exit 1
dkms build   -m nvidia -v $DRIVER_VER \
    --kernelsourcedir $KERNEL_SRC --kernel $KERNEL_VER || exit 1
dkms install -m nvidia -v $DRIVER_VER \
    --kernel $KERNEL_VER                               || exit 1

# ── Cleanup ───────────────────────────────────────────────────────────────────
rm -rf $EXTRACT_DIR

echo ""
echo ">>> install-nvdriver complete."
