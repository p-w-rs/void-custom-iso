#!/usr/bin/env fish

# build-mlterm
# Runs INSIDE the chroot.
# Builds mlterm-fb from source in /opt/mlterm and installs it system-wide.
#
# The source tree must already exist at /opt/mlterm — it is copied there from
# custom-files/opt/mlterm by run-chroot, which itself is populated by:
#   git submodule update --init custom-files/opt/mlterm

set SRC    /opt/mlterm
set PREFIX /usr/local

echo "=== Building mlterm-fb ==="
echo ""

# ── Sanity check ──────────────────────────────────────────────────────────────
# The mlterm repo ships a pre-generated ./configure script — no autoreconf needed.
# If it's missing, the submodule was never initialised on the host.
if not test -x $SRC/configure
    echo "ERROR: $SRC/configure not found."
    echo ""
    echo "The mlterm submodule has not been initialised. On the HOST, run:"
    echo "  git submodule update --init custom-files/opt/mlterm"
    echo "Then re-run run-chroot."
    exit 1
end

# ── Configure ─────────────────────────────────────────────────────────────────
# --with-gui=fb          build the framebuffer binary (mlterm-fb)
# --disable-xlib         no X11 dependency
# --prefix=/usr/local    system-wide, outside xbps management
# --enable-vt52          extra terminal compat
# --disable-ssh2         no SSH tunnelling (use external ssh)
# --disable-otl          no OpenType layout (harfbuzz not installed)
# --disable-dnd          no XDnD (X11 only)
# sixel/image support is ON by default (do NOT pass --disable-image)
# fontconfig is ON by default for framebuffer builds when the lib is present

echo ">>> Configuring (framebuffer target, sixel enabled)..."
cd $SRC
./configure \
    --prefix=$PREFIX \
    --with-gui=fb \
    --disable-xlib \
    --enable-vt52 \
    --disable-ssh2 \
    --disable-otl \
    --disable-dnd \
    --disable-iiimf \
    --disable-uim \
    --disable-scim \
    --disable-m17nlib \
    --disable-ibus \
    --disable-fcitx \
    --disable-canna \
    --disable-wnn \
    --disable-skk \
    || exit 1

# ── Build ─────────────────────────────────────────────────────────────────────
echo ""
echo ">>> Compiling (using "(nproc)" cores)..."
make -j(nproc) || exit 1

# ── Install ───────────────────────────────────────────────────────────────────
echo ""
echo ">>> Installing to $PREFIX..."
make install || exit 1

# ── Verify ────────────────────────────────────────────────────────────────────
echo ""
if test -x $PREFIX/bin/mlterm-fb
    echo ">>> mlterm-fb installed: "(command -v mlterm-fb || echo $PREFIX/bin/mlterm-fb)
else
    echo "ERROR: mlterm-fb binary not found after install."
    exit 1
end

echo ""
echo ">>> build-mlterm complete."
