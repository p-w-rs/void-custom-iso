#!/usr/bin/env fish

# enable-services
# Runs INSIDE the chroot.
# Reads /etc/void-install/services and symlinks each into runit.

set SERVICES_FILE /etc/void-install/services

if not test -f $SERVICES_FILE
    echo "ERROR: $SERVICES_FILE not found."
    exit 1
end

echo "=== Enabling Runit Services ==="
echo ""

for svc in (grep -v '^\s*#' $SERVICES_FILE | grep -v '^\s*$')
    if test -d /etc/sv/$svc
        ln -sf /etc/sv/$svc /etc/runit/runsvdir/default/
        echo "    [ENABLED] $svc"
    else
        echo "    [SKIPPED] $svc (not found in /etc/sv)"
    end
end

echo ""
echo ">>> enable-services complete."
