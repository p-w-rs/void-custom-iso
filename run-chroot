#!/usr/bin/env fish

# run-chroot — copy custom-files into /mnt and run each chroot script in order.
# Run on the HOST after install-pkgs and mount-disk.
#
# Usage:
#   sudo fish run-chroot              → internal drive (writes NVRAM)
#   sudo fish run-chroot --removable  → USB/image (no NVRAM, fallback EFI path)
#
# To add a chroot step: drop a script in custom-files/tmp/chroot/ and add it
# to the SCRIPTS list below. Scripts run as /usr/bin/fish inside the chroot.

source (dirname (status filename))/helpers/die

set CHROOT /mnt
set SDIR   /tmp/chroot

# Pass --removable through to install-grub if requested
set GRUB_FLAGS
contains -- --removable $argv; and set GRUB_FLAGS --removable

# ── Copy config files into the chroot ─────────────────────────────────────────
echo ">>> Copying custom-files..."
run sudo cp -rv (dirname (status filename))/custom-files/. $CHROOT/

# ── Download NVIDIA assets (skipped if already present) ───────────────────────
# Driver 580.x pairs with CUDA 13.0. Update versions here and in the two
# install-nvdriver / install-cuda chroot scripts when upgrading.
run wget -P $CHROOT/tmp -nc \
    https://us.download.nvidia.com/XFree86/Linux-x86_64/580.126.18/NVIDIA-Linux-x86_64-580.126.18.run
run wget -P $CHROOT/tmp -nc \
    https://developer.download.nvidia.com/compute/cuda/13.0.0/local_installers/cuda_13.0.0_580.65.06_linux.run

run sudo chmod +x $CHROOT$SDIR/*

# ── Run each script inside the chroot ─────────────────────────────────────────
# Order matters: apply-config sets up the system, nvdriver/cuda build the GPU
# stack, setup-fish installs shell plugins, enable-services links runit dirs,
# install-grub writes the bootloader, finalize reconfigures all packages.

set SCRIPTS apply-config install-nvdriver install-cuda setup-fish enable-services install-grub finalize

for script in $SCRIPTS
    echo ""
    echo ">>> $script"

    set flags
    test $script = install-grub; and set flags $GRUB_FLAGS

    xchroot $CHROOT /usr/bin/fish $SDIR/$script $flags
    or die "$script failed"
end

echo ""
echo ">>> All done. Unmount with:"
echo "    sudo swapoff LABEL=swap && sudo umount -R /mnt"
