#!/usr/bin/env fish

# run-chroot
# Run on the HOST after setup-config.
# Copies scripts and config into the chroot, then runs them via xchroot.

set CHROOT /mnt
set SCRIPT_DIR (dirname (status filename))/chroot
set CHROOT_SCRIPT_DIR $CHROOT/root/void-setup

# ── Preflight checks ──────────────────────────────────────────────────────────
if not test -f $SCRIPT_DIR/config
    echo "ERROR: config file not found. Run setup-config first."
    exit 1
end

if not test -d $CHROOT/etc
    echo "ERROR: $CHROOT does not look like a mounted Void installation."
    exit 1
end

# ── Generate fstab by label ───────────────────────────────────────────────────
# We write fstab manually using labels rather than xgenfstab because xgenfstab
# scans all host-mounted filesystems and bleeds in host entries (e.g. the host
# swap). Our prep-img / prep-disk scripts always assign these exact labels, so
# this fstab is correct for any machine the image is booted on.
echo ">>> Writing fstab..."
sudo tee $CHROOT/etc/fstab > /dev/null << 'EOF'
# <file system>   <dir>      <type>   <options>          <dump>  <pass>
LABEL=root        /          ext4     defaults,relatime  0       1
LABEL=EFI         /boot/efi  vfat     defaults,noatime   0       2
LABEL=swap        none       swap     sw                 0       0
EOF
echo "    Done."
cat $CHROOT/etc/fstab

# ── Copy scripts and config into chroot ───────────────────────────────────────
echo ">>> Copying scripts into chroot at $CHROOT_SCRIPT_DIR..."
sudo mkdir -p $CHROOT_SCRIPT_DIR
sudo cp $SCRIPT_DIR/config          $CHROOT_SCRIPT_DIR/
sudo cp $SCRIPT_DIR/apply-config    $CHROOT_SCRIPT_DIR/
sudo cp $SCRIPT_DIR/enable-services $CHROOT_SCRIPT_DIR/
sudo cp $SCRIPT_DIR/install-grub    $CHROOT_SCRIPT_DIR/
sudo cp $SCRIPT_DIR/finalize        $CHROOT_SCRIPT_DIR/
sudo chmod +x $CHROOT_SCRIPT_DIR/apply-config \
              $CHROOT_SCRIPT_DIR/enable-services \
              $CHROOT_SCRIPT_DIR/install-grub \
              $CHROOT_SCRIPT_DIR/finalize

# ── Run scripts inside chroot ─────────────────────────────────────────────────
echo ""
echo ">>> Running apply-config inside chroot..."
xchroot $CHROOT /usr/bin/fish /root/void-setup/apply-config || exit 1

echo ""
echo ">>> Running enable-services inside chroot..."
xchroot $CHROOT /usr/bin/fish /root/void-setup/enable-services || exit 1

echo ""
echo ">>> Running install-grub inside chroot..."
xchroot $CHROOT /usr/bin/fish /root/void-setup/install-grub || exit 1

echo ""
echo ">>> Running finalize inside chroot..."
xchroot $CHROOT /usr/bin/fish /root/void-setup/finalize || exit 1

# ── Cleanup ───────────────────────────────────────────────────────────────────
echo ""
echo ">>> Cleaning up scripts from chroot..."
sudo rm -rf $CHROOT_SCRIPT_DIR

echo ""
echo ">>> All done. Next steps:"
echo "    1. sudo swapoff LABEL=swap"
echo "    2. sudo umount -R /mnt"
echo "    3. sudo losetup -d <loop device>  (if using an image)"
echo "    4. Transfer image and boot"
