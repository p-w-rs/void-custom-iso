#!/usr/bin/env fish
# run-chroot-scripts.fish
# Run on the HOST after setup-config.fish.
# Copies scripts and config into the chroot, then runs them via xchroot.

set CHROOT /mnt
set SCRIPT_DIR (dirname (status filename))/chroot
set CHROOT_SCRIPT_DIR $CHROOT/root/void-setup

# ── Preflight checks ──────────────────────────────────────────────────────────
if not test -f $SCRIPT_DIR/config
    echo "ERROR: config file not found. Run setup-config first."
    exit 1
end

if not test -d $CHROOT/etc
    echo "ERROR: $CHROOT does not look like a mounted Void installation."
    exit 1
end

# ── Generate fstab ────────────────────────────────────────────────────────────
echo ">>> Generating fstab..."
xgenfstab -U $CHROOT > $CHROOT/etc/fstab
echo "    Done."
cat $CHROOT/etc/fstab

# ── Copy scripts and config into chroot ───────────────────────────────────────
echo ">>> Copying scripts into chroot at $CHROOT_SCRIPT_DIR..."
mkdir -p $CHROOT_SCRIPT_DIR
cp $SCRIPT_DIR/config    $CHROOT_SCRIPT_DIR/
cp $SCRIPT_DIR/apply-config $CHROOT_SCRIPT_DIR/
cp $SCRIPT_DIR/enable-services $CHROOT_SCRIPT_DIR/
chmod +x $CHROOT_SCRIPT_DIR/*

# ── Run scripts inside chroot ─────────────────────────────────────────────────
echo ""
echo ">>> Running configure-void.fish inside chroot..."
xchroot $CHROOT /usr/bin/fish /root/void-setup/config

echo ""
echo ">>> Running enable-services.fish inside chroot..."
xchroot $CHROOT /usr/bin/fish /root/void-setup/enable-services

# ── Cleanup ───────────────────────────────────────────────────────────────────
echo ""
echo ">>> Cleaning up scripts from chroot..."
rm -rf $CHROOT_SCRIPT_DIR

echo ""
echo ">>> All done. Next steps:"
echo "    1. umount -R /mnt"
echo "    2. reboot"
