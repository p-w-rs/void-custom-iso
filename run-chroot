#!/usr/bin/env fish

# run-chroot
# Run on the HOST after editing custom-files/.
# Copies custom-files into the target, then runs chroot scripts in order.
#
# Usage:
#   sudo fish run-chroot              → internal drive (default)
#   sudo fish run-chroot --removable  → USB / portable image

set ROOT       (dirname (status filename))
set CHROOT     /mnt
set WORK       $CHROOT/root/void-setup

# ── Parse arguments ────────────────────────────────────────────────────────────
set GRUB_FLAGS
if contains -- --removable $argv
    set GRUB_FLAGS --removable
end

# ── Copy custom-files into chroot ──────────────────────────────────────────────
echo ">>> Copying custom-files..."
sudo cp -rv $ROOT/custom-files/. $CHROOT/ || exit 1

# ── Download NVIDIA assets ─────────────────────────────────────────────────────
# Driver 580.x pairs with CUDA 13.0. To update versions, change these URLs
# and update DRIVER_VER / CUDA_VER in chroot/install-nvdriver and chroot/install-cuda.
wget -P $CHROOT/tmp -nc https://us.download.nvidia.com/XFree86/Linux-x86_64/580.126.18/NVIDIA-Linux-x86_64-580.126.18.run || exit 1
wget -P $CHROOT/tmp -nc https://developer.download.nvidia.com/compute/cuda/13.0.0/local_installers/cuda_13.0.0_580.65.06_linux.run || exit 1

# ── Copy and arm chroot scripts ────────────────────────────────────────────────
echo ">>> Copying chroot scripts..."
sudo mkdir -p $WORK
sudo cp $ROOT/chroot/* $WORK/
sudo chmod +x $WORK/* || exit 1

# ── Run scripts inside chroot ──────────────────────────────────────────────────
# To add a new chroot step: drop a script in chroot/ and add it to this list.
for script in apply-config install-nvdriver install-cuda enable-services install-grub finalize
    echo ""
    echo ">>> Running $script..."
    xchroot $CHROOT /usr/bin/fish /root/void-setup/$script $GRUB_FLAGS || exit 1
end

# ── Cleanup ────────────────────────────────────────────────────────────────────
sudo rm -rf $WORK
echo ""
echo ">>> All done. Unmount with: sudo swapoff LABEL=swap && sudo umount -R /mnt"
