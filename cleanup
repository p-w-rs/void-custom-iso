#!/usr/bin/env fish

# cleanup
# Unmounts the installed system and cleans up the device.
#
# Loop device  → zeros free blocks, converts void.img to void.qcow2, detaches loop
# Physical disk → just unmounts cleanly
#
# Usage:
#   ./cleanup /dev/loop0       (disk image / loop device)
#   ./cleanup /dev/sda         (physical SATA/SCSI disk)
#   ./cleanup /dev/nvme0n1     (physical NVMe disk)

set MOUNT_ROOT /mnt
set IMG        void.img
set OUT        void.qcow2

# ── Argument handling ──────────────────────────────────────────────────────────
if test (count $argv) -ne 1
    echo "Usage: "(status filename)" <device>"
    echo "  e.g. "(status filename)" /dev/loop0"
    echo "  e.g. "(status filename)" /dev/sda"
    echo "  e.g. "(status filename)" /dev/nvme0n1"
    exit 1
end

set DEV $argv[1]

# Detect partition suffix and whether this is a loop device
if string match -qr 'loop' $DEV
    set IS_LOOP  true
    set PART_SWAP {$DEV}p2
    set PART_ROOT {$DEV}p3
else if string match -qr 'nvme' $DEV
    set IS_LOOP  false
    set PART_SWAP {$DEV}p2
    set PART_ROOT {$DEV}p3
else
    set IS_LOOP  false
    set PART_SWAP {$DEV}2
    set PART_ROOT {$DEV}3
end

echo "Device:  $DEV"
echo "Mode:    "(if $IS_LOOP; echo "loop — will convert to qcow2"; else; echo "physical disk"; end)
echo ""

# ── 1. Unmount EFI ─────────────────────────────────────────────────────────────
echo ">>> Unmounting EFI partition..."
sudo umount $MOUNT_ROOT/boot/efi || exit 1

# ── 2. Disable swap ────────────────────────────────────────────────────────────
echo ">>> Disabling swap..."
sudo swapoff $PART_SWAP || exit 1

# ── 3. Unmount root ────────────────────────────────────────────────────────────
echo ">>> Unmounting root filesystem..."
sudo umount $MOUNT_ROOT || exit 1

# ── 4. Loop-device path: zerofree + qcow2 conversion ──────────────────────────
if $IS_LOOP
    echo ""
    echo ">>> Zeroing free blocks on root partition (improves compression)..."
    sudo zerofree -v $PART_ROOT || exit 1

    echo ""
    echo ">>> Converting $IMG → $OUT (compressed qcow2)..."
    qemu-img convert -f raw -O qcow2 -c $IMG $OUT || exit 1

    echo ""
    echo ">>> Detaching loop device $DEV..."
    sudo losetup -d $DEV || exit 1

    echo ""
    echo ">>> Conversion complete."
    qemu-img info $OUT

# ── 5. Physical disk path: nothing more to do ─────────────────────────────────
else
    echo ""
    echo ">>> Physical disk unmounted cleanly. Nothing more to do."
end

echo ""
echo ">>> cleanup complete."
