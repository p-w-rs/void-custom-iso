#!/usr/bin/env fish

# install-pkgs — bootstrap the Void Linux package tree into /mnt.
# Run on the HOST after mount-disk, before run-chroot.
#
# To add packages: either append to PACKAGES below, or drop a .fish file
# in packages/ that appends to $PACKAGES (see existing files for the pattern).
# To add a repo: append -R <url> to the xbps-install call at the bottom.

source (dirname (status filename))/helpers/die

# ── Repos and target ──────────────────────────────────────────────────────────
set REPOS      -R https://repo-default.voidlinux.org/current \
               -R https://repo-default.voidlinux.org/current/nonfree
set ARCH       x86_64
set TARGET     /mnt

# ── Packages to ignore (never installed, even as dependencies) ────────────────
# Kept out to avoid conflicts: linux (we use linux-mainline), nvidia upstream
# packages (we install from .run), mesa-nouveau (replaced by proprietary driver).
set IGNORE     linux linux-headers nvidia mesa-nouveau-dri

# ── Base packages ─────────────────────────────────────────────────────────────
set PACKAGES \
    base-system linux-mainline linux-mainline-headers void-repo-nonfree \
    linux-firmware linux-firmware-dvb linux-firmware-intel \
    linux-firmware-network linux-firmware-nvidia \
    acpi chrony dhcpcd wpa_supplicant openssh \
    nftables runit-nftables apparmor dbus bluez \
    sudo fish-shell nerd-fonts net-tools xtools \
    parted grub-x86_64-efi glibc-locales

# ── Optional package sets (source each file in packages/) ─────────────────────
for f in (dirname (status filename))/packages/*.fish
    source $f
end

# ── Write ignorepkg config before installing ──────────────────────────────────
run sudo mkdir -p $TARGET/var/db/xbps/keys $TARGET/etc/xbps.d
run sudo cp /var/db/xbps/keys/* $TARGET/var/db/xbps/keys/

for pkg in $IGNORE
    echo "ignorepkg=$pkg" | sudo tee -a $TARGET/etc/xbps.d/10-ignore.conf
end

# ── Install ───────────────────────────────────────────────────────────────────
echo "Installing packages to $TARGET..."
run sudo env XBPS_ARCH=$ARCH xbps-install -Su $REPOS -r $TARGET $PACKAGES

echo ""
echo ">>> install-pkgs done. Ignored: $IGNORE"
