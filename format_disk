#!/usr/bin/env fish

# ── Configuration ─────────────────────────────────────────────────────────────
set IMG_FILE   void.img
set IMG_SIZE   64G
set EFI_SIZE   101MiB
set SWAP_END   4101MiB

# ── 1. Create disk image ───────────────────────────────────────────────────────
echo "Creating disk image: $IMG_FILE ($IMG_SIZE)..."
truncate -s $IMG_SIZE $IMG_FILE || exit 1

# ── 2. Attach loop device ──────────────────────────────────────────────────────
echo "Attaching loop device..."
set LOOP (sudo losetup --find --partscan --show $IMG_FILE) || exit 1
echo "Using loop device: $LOOP"

# ── 3. Partition the loop device ───────────────────────────────────────────────
echo "Partitioning $LOOP..."
sudo parted --script $LOOP \
    mklabel gpt \
    mkpart EFI  fat32      1MiB     $EFI_SIZE \
    mkpart swap linux-swap $EFI_SIZE $SWAP_END \
    mkpart root ext4       $SWAP_END 100% \
    set 1 esp on || exit 1

sleep 1

# ── 4. Format partitions ───────────────────────────────────────────────────────
echo "Formatting partitions..."
sudo mkfs.vfat -F32 -n EFI  {$LOOP}p1 || exit 1
sudo mkswap    -L swap       {$LOOP}p2 || exit 1
sudo mkfs.ext4 -L root       {$LOOP}p3 || exit 1

echo ""
echo "Done! Loop device: $LOOP"
echo "When finished, detach with: sudo losetup -d $LOOP"
