# /etc/mlterm/font-fb
# PCF/bitmap font configuration for mlterm-fb (framebuffer-specific).
# Per-user overrides go in ~/.mlterm/font-fb
#
# When freetype/fontconfig are available (which they are in this build),
# mlterm-fb prefers aafont over font-fb.  This file acts as a fallback
# and is only consulted for character sets not covered by the aafont config.
#
# The unifont PCF covers the entire BMP and is the best single fallback.
# Install with: xbps-install -S font-unifont-bdf  (or font-misc-misc)
#
# Uncomment if you want a PCF fallback for glyphs not found via fontconfig:
# ISO10646_UCS4_1 = /usr/share/fonts/X11/misc/unifont.pcf.gz:100
