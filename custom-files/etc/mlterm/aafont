# /etc/mlterm/aafont
# Anti-aliased (freetype/fontconfig) font configuration for mlterm-fb.
# Per-user overrides go in ~/.mlterm/aafont
#
# Font names are passed directly to fontconfig — use the same names you'd
# use with fc-list or fc-match.  Leave DEFAULT unset to let fontconfig pick
# based on the system font stack, or pin it to a specific family.
#
# Good monospace choices available in Void repos:
#   font-hack-ttf       → "Hack"
#   font-jetbrains-mono → "JetBrains Mono"
#   font-fira-mono      → "Fira Mono"
#   noto-fonts-ttf      → "Noto Sans Mono"  (widest Unicode coverage)
#   terminus-font       → "Terminus" (bitmap-style, excellent at small sizes)
#
# Uncomment and change to your preferred font family:
# DEFAULT = Hack 16
# DEFAULT = JetBrains Mono 16
# DEFAULT = Terminus 16

# Fallback for full Unicode coverage (CJK, emoji, etc.)
# ISO10646_UCS4_1 = Noto Sans Mono
