#!/usr/bin/env fish

# install-nvdriver
# Runs INSIDE the chroot.
# Installs the NVIDIA open kernel module driver from the official .run installer.
# Uses a manual extract-and-build approach to avoid the tegra headers bug in
# the .run installer's built-in build system on x86_64 + CONFIG_COMMON_CLK.
#
# Run order: install-pkgs → install-nvdriver → install-cuda → finalize

source (dirname (status filename))/die

set DRIVER_VER  580.126.18
set DRIVER_RUN  /tmp/NVIDIA-Linux-x86_64-{$DRIVER_VER}.run
set EXTRACT_DIR /tmp/nvidia-extract
set KERNEL_VER  (uname -r)
set KERNEL_SRC  /usr/src/kernel-headers-{$KERNEL_VER}

echo "=== NVIDIA Driver Installation ==="
echo ""

# ── Step 1: Extract ───────────────────────────────────────────────────────────
# --extract-only lets us drive the kernel build ourselves with explicit
# TARGET_ARCH=x86_64, bypassing the installer's broken tegra detection.
echo ">>> Extracting..."
rm -rf $EXTRACT_DIR
run $DRIVER_RUN --extract-only --target $EXTRACT_DIR

# ── Step 2: Userspace components ─────────────────────────────────────────────
echo ">>> Installing userspace components..."
run $DRIVER_RUN \
    --silent \
    --no-kernel-module \
    --install-libglvnd \
    --no-nvidia-modprobe \
    --no-nouveau-check \
    --no-backup \
    --no-questions

# ── Step 3: Build open kernel modules ────────────────────────────────────────
# TARGET_ARCH=x86_64 prevents the Kbuild system from pulling in arm64/tegra
# code paths even when CONFIG_COMMON_CLK is set.
echo ">>> Building kernel modules..."
cd $EXTRACT_DIR/kernel-open

# nv-clk.c unconditionally includes <soc/tegra/bpmp-abi.h> which doesn't exist
# on x86_64. Stub it out — nothing on x86 calls into the clock management code.
printf '#include <linux/types.h>\n
// nv-clk.c stub for x86_64 — the real file includes <soc/tegra/bpmp-abi.h>
// which does not exist on x86. These symbols are referenced by nvidia.ko but
// are no-ops on non-Tegra hardware.
int  nv_enable_clk(void *h)               { return 0; }
int  nv_disable_clk(void *h)              { return 0; }
int  nv_get_max_freq(void *h)             { return 0; }
int  nv_set_freq(void *h, u32 f)          { return 0; }
void nv_clk_get_handles(void *d, void **h, u32 *n) {}
void nv_clk_clear_handles(void *d)        {}
' > nvidia/nv-clk.c

# GCC ICE workaround: this file crashes the compiler at -O2 on GCC 14+.
# Force -O1 for just this translation unit via the kbuild per-file mechanism.
printf 'CFLAGS_uvm_gpu_access_counters.o := -O1\n' \
    >> nvidia-uvm/Makefile

run make modules \
    TARGET_ARCH=x86_64 \
    KERNEL_UNAME=$KERNEL_VER \
    SYSSRC=$KERNEL_SRC \
    SYSOUT=$KERNEL_SRC \
    NV_VERBOSE=1 \
    EXTRA_CFLAGS="-Wno-missing-prototypes" \
    -j(nproc)

# ── Step 4: Install modules ───────────────────────────────────────────────────
echo ">>> Installing kernel modules..."
run make modules_install \
    TARGET_ARCH=x86_64 \
    KERNEL_UNAME=$KERNEL_VER

# ── Step 5: Register with DKMS ───────────────────────────────────────────────
# Copies source to /usr/src/nvidia-$DRIVER_VER so DKMS rebuilds on kernel updates.
echo ">>> Registering with DKMS..."
mkdir -p /usr/src/nvidia-$DRIVER_VER
cp -r $EXTRACT_DIR/kernel-open/* /usr/src/nvidia-$DRIVER_VER/

# Re-apply patches to the DKMS source tree so future kernel rebuilds also work.
printf '#include <linux/types.h>\n
int  nv_enable_clk(void *h)               { return 0; }
int  nv_disable_clk(void *h)              { return 0; }
int  nv_get_max_freq(void *h)             { return 0; }
int  nv_set_freq(void *h, u32 f)          { return 0; }
void nv_clk_get_handles(void *d, void **h, u32 *n) {}
void nv_clk_clear_handles(void *d)        {}
' > /usr/src/nvidia-$DRIVER_VER/nvidia/nv-clk.c

printf 'CFLAGS_uvm_gpu_access_counters.o := -O1\n' \
    >> /usr/src/nvidia-$DRIVER_VER/nvidia-uvm/Makefile

# The extracted dkms.conf has unsubstituted placeholders — rewrite it cleanly.
# BUILT_MODULE_NAME/DEST_MODULE_LOCATION entries must cover all five .ko files.
printf 'PACKAGE_NAME="nvidia"
PACKAGE_VERSION="%s"
AUTOINSTALL="yes"
MAKE[0]="'"'"'make'"'"' -j$(nproc) KERNEL_UNAME=${kernelver} TARGET_ARCH=x86_64 SYSSRC=%s modules"
BUILT_MODULE_NAME[0]="nvidia"
BUILT_MODULE_NAME[1]="nvidia-uvm"
BUILT_MODULE_NAME[2]="nvidia-modeset"
BUILT_MODULE_NAME[3]="nvidia-drm"
BUILT_MODULE_NAME[4]="nvidia-peermem"
DEST_MODULE_LOCATION[0]="/kernel/drivers/video"
DEST_MODULE_LOCATION[1]="/kernel/drivers/video"
DEST_MODULE_LOCATION[2]="/kernel/drivers/video"
DEST_MODULE_LOCATION[3]="/kernel/drivers/video"
DEST_MODULE_LOCATION[4]="/kernel/drivers/video"
' $DRIVER_VER $KERNEL_SRC > /usr/src/nvidia-$DRIVER_VER/dkms.conf

run dkms add     -m nvidia -v $DRIVER_VER --force
dkms build   -m nvidia -v $DRIVER_VER \
    --kernelsourcedir $KERNEL_SRC -k $KERNEL_VER
or begin
    echo ">>> DKMS build failed — make.log:"
    cat /var/lib/dkms/nvidia/$DRIVER_VER/build/make.log
    exit 1
end
run dkms install -m nvidia -v $DRIVER_VER -k $KERNEL_VER --force

# ── Cleanup ───────────────────────────────────────────────────────────────────
rm -rf $EXTRACT_DIR

echo ""
echo ">>> install-nvdriver complete."
