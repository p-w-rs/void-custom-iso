#!/usr/bin/env fish

# install-nvdriver — runs INSIDE the chroot.
# Installs the NVIDIA open kernel module driver from the official .run installer.
#
# We extract manually rather than using the installer's built-in build system
# because it has a tegra headers bug on x86_64 + CONFIG_COMMON_CLK that causes
# it to pull in arm64 code paths and fail. Extract-and-build sidesteps this.
#
# Run order: install-pkgs → install-nvdriver → install-cuda → finalize
#
# To upgrade: update DRIVER_VER and the .run URL in run-chroot.

set DRIVER_VER 580.126.18
set DRIVER_RUN /tmp/NVIDIA-Linux-x86_64-{$DRIVER_VER}.run
set EXTRACT    /tmp/nvidia-extract
set KERNEL_VER (uname -r)
set KERNEL_SRC /usr/src/kernel-headers-{$KERNEL_VER}

echo "=== NVIDIA Driver $DRIVER_VER ==="

# ── 1. Extract ────────────────────────────────────────────────────────────────
# --extract-only lets us pass TARGET_ARCH=x86_64 to make ourselves,
# bypassing the installer's broken tegra detection.
echo ">>> Extracting..."
rm -rf $EXTRACT
$DRIVER_RUN --extract-only --target $EXTRACT; or exit 1

# ── 2. Userspace components ───────────────────────────────────────────────────
echo ">>> Installing userspace components..."
$DRIVER_RUN \
    --silent \
    --no-kernel-module \
    --install-libglvnd \
    --no-nvidia-modprobe \
    --no-nouveau-check \
    --no-backup \
    --no-questions
or exit 1

# ── 3. Patch nv-clk.c ────────────────────────────────────────────────────────
# nv-clk.c unconditionally includes <soc/tegra/bpmp-abi.h> which doesn't exist
# on x86_64. We stub it out — nothing on x86 calls into clock management code.
echo ">>> Patching nv-clk.c for x86_64..."
printf '
#include <linux/types.h>
// x86_64 stub — real file includes <soc/tegra/bpmp-abi.h> which does not exist here.
// These symbols are referenced by nvidia.ko but are no-ops on non-Tegra hardware.
int  nv_enable_clk(void *h)                { return 0; }
int  nv_disable_clk(void *h)               { return 0; }
int  nv_get_max_freq(void *h)              { return 0; }
int  nv_set_freq(void *h, u32 f)           { return 0; }
void nv_clk_get_handles(void *d, void **h, u32 *n) {}
void nv_clk_clear_handles(void *d)         {}
' > $EXTRACT/kernel-open/nvidia/nv-clk.c

# ── 4. Work around GCC ICE in uvm_gpu_access_counters.c ──────────────────────
# GCC crashes with an internal compiler error on this file at -O2.
# Inject a per-file kbuild flag to force -O1 for just this translation unit.
echo ">>> Patching uvm_gpu_access_counters optimization level..."
printf 'CFLAGS_uvm_gpu_access_counters.o := -O1\n' \
    >> $EXTRACT/kernel-open/nvidia-uvm/Makefile

# ── 5. Build kernel modules ───────────────────────────────────────────────────
echo ">>> Building kernel modules..."
make -C $EXTRACT/kernel-open modules \
    TARGET_ARCH=x86_64 \
    KERNEL_UNAME=$KERNEL_VER \
    SYSSRC=$KERNEL_SRC \
    SYSOUT=$KERNEL_SRC \
    NV_VERBOSE=1 \
    EXTRA_CFLAGS="-Wno-missing-prototypes" \
    -j(nproc)
or exit 1

# ── 6. Install modules ────────────────────────────────────────────────────────
echo ">>> Installing kernel modules..."
make -C $EXTRACT/kernel-open modules_install \
    TARGET_ARCH=x86_64 \
    KERNEL_UNAME=$KERNEL_VER \
    SYSSRC=$KERNEL_SRC \
    SYSOUT=$KERNEL_SRC
or exit 1

# ── 7. Register with DKMS ────────────────────────────────────────────────────
# Copies source to /usr/src/nvidia-$DRIVER_VER so DKMS rebuilds on kernel updates.
# We rewrite dkms.conf because the extracted version has unsubstituted placeholders.
echo ">>> Registering with DKMS..."
set DKMS_SRC /usr/src/nvidia-$DRIVER_VER
mkdir -p $DKMS_SRC
cp -r $EXTRACT/kernel-open/* $DKMS_SRC/

# Re-apply patches to the DKMS source tree so rebuilds work correctly.
printf '
#include <linux/types.h>
int  nv_enable_clk(void *h)                { return 0; }
int  nv_disable_clk(void *h)               { return 0; }
int  nv_get_max_freq(void *h)              { return 0; }
int  nv_set_freq(void *h, u32 f)           { return 0; }
void nv_clk_get_handles(void *d, void **h, u32 *n) {}
void nv_clk_clear_handles(void *d)         {}
' > $DKMS_SRC/nvidia/nv-clk.c

printf 'CFLAGS_uvm_gpu_access_counters.o := -O1\n' \
    >> $DKMS_SRC/nvidia-uvm/Makefile

printf 'PACKAGE_NAME="nvidia"
PACKAGE_VERSION="%s"
AUTOINSTALL="yes"
MAKE[0]="make -j$(nproc) KERNEL_UNAME=${kernelver} TARGET_ARCH=x86_64 SYSSRC=%s SYSOUT=%s EXTRA_CFLAGS=-Wno-missing-prototypes modules"
BUILT_MODULE_NAME[0]="nvidia"
BUILT_MODULE_NAME[1]="nvidia-uvm"
BUILT_MODULE_NAME[2]="nvidia-modeset"
BUILT_MODULE_NAME[3]="nvidia-drm"
BUILT_MODULE_NAME[4]="nvidia-peermem"
DEST_MODULE_LOCATION[0]="/kernel/drivers/video"
DEST_MODULE_LOCATION[1]="/kernel/drivers/video"
DEST_MODULE_LOCATION[2]="/kernel/drivers/video"
DEST_MODULE_LOCATION[3]="/kernel/drivers/video"
DEST_MODULE_LOCATION[4]="/kernel/drivers/video"
' $DRIVER_VER $KERNEL_SRC $KERNEL_SRC > $DKMS_SRC/dkms.conf

dkms add     -m nvidia -v $DRIVER_VER --force;                                       or exit 1
dkms build   -m nvidia -v $DRIVER_VER --kernelsourcedir $KERNEL_SRC -k $KERNEL_VER; or exit 1
dkms install -m nvidia -v $DRIVER_VER -k $KERNEL_VER --force;                       or exit 1

rm -rf $EXTRACT
echo ">>> install-nvdriver done."
