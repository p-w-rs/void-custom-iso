#!/usr/bin/env fish

# install-grub — runs INSIDE the chroot.
# Installs GRUB for UEFI and generates grub.cfg.
#
# Usage:
#   install-grub              → internal drive (writes NVRAM entry)
#   install-grub --removable  → USB/image (fallback EFI path, no NVRAM)

echo "=== GRUB Installation ==="

mountpoint -q /boot/efi; or begin; echo "ERROR: /boot/efi not mounted"; exit 1; end

# --removable  → installs to /EFI/BOOT/BOOTX64.EFI so any machine can boot it
# --no-nvram   → don't write boot entries into the host firmware (safe in chroot)
set FLAGS
contains -- --removable $argv; and set FLAGS --removable --no-nvram

echo ">>> grub-install..."
grub-install \
    --target=x86_64-efi \
    --efi-directory=/boot/efi \
    --bootloader-id=void \
    --recheck \
    $FLAGS
or exit 1

echo ">>> grub-mkconfig..."
grub-mkconfig -o /boot/grub/grub.cfg; or exit 1

echo ">>> install-grub done."
