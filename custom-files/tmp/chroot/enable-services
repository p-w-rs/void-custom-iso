#!/usr/bin/env fish

# enable-services — runs INSIDE the chroot.
# Symlinks each service listed in /tmp/services into runit's default runsvdir.
# Edit custom-files/tmp/services to add or remove services.

source (dirname (status filename))/die

set SERVICES_FILE /tmp/services
run test -f $SERVICES_FILE

echo "=== Enabling Services ==="

for svc in (grep -v '^\s*[#$]' $SERVICES_FILE | grep -v '^\s*$')
    if test -d /etc/sv/$svc
        ln -sf /etc/sv/$svc /etc/runit/runsvdir/default/
        echo "  [on]  $svc"
    else
        echo "  [??]  $svc — not found in /etc/sv, skipped"
    end
end

echo ">>> enable-services done."
