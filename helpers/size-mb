#!/usr/bin/env fish

# Converts a human size (e.g. 100M, 4G, 512K) to a plain megabyte number.
# Usage: size-bm <size>
# Output: a plain integer (e.g. 4096)

if test (count $argv) -ne 1
    echo "Usage: size_to_mb.fish <size>  (e.g. 100M, 4G, 512K)"
    exit 1
end

set input $argv[1]

# Split the numeric part from the unit suffix
set num  (string replace -r '[KMGkmg]$' '' $input)
set unit (string upper (string match -r '[KMGkmg]$' $input))

switch $unit
    case K
        math "ceil($num / 1024)"
    case M
        math "$num"
    case G
        math "$num * 1024"
    case '*'
        echo "Error: unrecognised unit '$unit' — use K, M, or G"
        exit 1
end
